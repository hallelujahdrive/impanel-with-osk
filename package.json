{
	"name": "impanel-with-osk",
	"version": "7.0.0",
	"author": "hallelujahdrive",
	"main": "extension.js",
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@eslint/js": "^10.0.1",
		"@girs/gio-2.0": "2.86.0-4.0.0-beta.38",
		"@girs/gjs": "^4.0.0-beta.40",
		"@girs/glib-2.0": "^2.86.4-4.0.0-beta.40",
		"@girs/gnome-shell": "^49.1.0",
		"@girs/gobject-2.0": "^2.86.4-4.0.0-beta.40",
		"@girs/ibus-1.0": "^1.5.32-4.0.0-beta.40",
		"@typescript-eslint/parser": "^8.57.1",
		"eslint-plugin-perfectionist": "^5.7.0",
		"husky": "^9.1.7",
		"rolldown": "^1.0.0-rc.10",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.1"
	},
	"description": "IM Panel Integrated with OSK is a GNOME Shell extension that improves the operation of input methods on touch screens by adding several features to the GNOME OnScreen Keyboard.\nThis extension is based on [input-method-panel](https://extensions.gnome.org/extension/261/kimpanel/).",
	"license": "GPL-3.0-only",
	"scripts": {
		"build": "rolldown -c",
		"check": "biome check . && eslint .",
		"check:fix": "biome check --write . && eslint . --fix",
		"format": "biome format . && eslint .",
		"format:fix": "biome format --write . && eslint . --fix",
		"lint": "biome lint . && eslint .",
		"lint:fix": "biome lint --write . && eslint . --fix",
		"test": "echo \"Error: no test specified\" && exit 1",
		"typecheck": "tsc --noEmit --pretty",
		"prepare": "husky"
	},
	"type": "module"
}
